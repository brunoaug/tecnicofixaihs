        function toggleTheme() {
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            
            html.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            
            const icon = document.getElementById('themeIcon');
            const text = document.getElementById('themeText');
            
            if (newTheme === 'dark') {
                icon.className = 'fas fa-sun';
                text.textContent = 'Tema Claro';
            } else {
                icon.className = 'fas fa-moon';
                text.textContent = 'Tema Escuro';
            }
        }

        function loadTheme() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
            
            const icon = document.getElementById('themeIcon');
            const text = document.getElementById('themeText');
            
            if (savedTheme === 'dark') {
                icon.className = 'fas fa-sun';
                text.textContent = 'Tema Claro';
            }
        }

        function showPage(pageId) {
            document.querySelectorAll('.page-content').forEach(page => {
                page.classList.remove('active');
            });
            document.getElementById(pageId).classList.add('active');

            if (pageId === 'cscPage') {
                renderStamps('csc');
                createFilterButtons('csc');
                updateStats('csc');
            } else if (pageId === 'padraoPage') {
                renderStamps('padrao');
                createFilterButtons('padrao');
                updateStats('padrao');
            }
        }

        function renderStamps(type, filter = 'all') {
            const stamps = type === 'csc' ? stampsCSC : stampsPadrao;
            const grid = document.getElementById(type === 'csc' ? 'stampsGridCSC' : 'stampsGridPadrao');
            grid.innerHTML = '';

            let filteredStamps = filter === 'all' ? stamps : stamps.filter(s => s.category === filter);

            if (filteredStamps.length === 0) {
                grid.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">
                            <i class="fas fa-inbox"></i>
                        </div>
                        <h3>Nenhum carimbo encontrado</h3>
                        <p>Tente ajustar os filtros ou adicione um novo carimbo</p>
                    </div>
                `;
                return;
            }

            filteredStamps.forEach(stamp => {
                const card = createStampCard(stamp, type);
                grid.appendChild(card);
            });

            updateStats(type, filteredStamps.length);
        }

        function createStampCard(stamp, type) {
            const card = document.createElement('div');
            card.className = 'stamp-card';
            card.setAttribute('data-stamp-id', stamp.id);

            const header = document.createElement('div');
            header.className = `stamp-header color-${stamp.color}`;
            header.textContent = stamp.title;

            const body = document.createElement('div');
            body.className = 'stamp-body';

            stamp.fields.forEach(field => {
                const fieldDiv = document.createElement('div');
                fieldDiv.className = 'stamp-field';
                
                const label = document.createElement('label');
                label.textContent = field.label;
                
                const isTextarea = field.label.includes('Observação') || 
                                  field.label.includes('OBS') || 
                                  field.label.includes('Descrição') ||
                                  field.label.includes('Solicitação') ||
                                  field.label.includes('EXPURGO');
                
                const input = isTextarea ? document.createElement('textarea') : document.createElement('input');
                
                if (!isTextarea) input.type = 'text';
                input.value = field.value;
                input.placeholder = field.value || `Digite ${field.label.toLowerCase()}`;
                input.onchange = (e) => updateFieldValue(stamp.id, field.label, e.target.value, type);

                fieldDiv.appendChild(label);
                fieldDiv.appendChild(input);
                body.appendChild(fieldDiv);
            });

            const actions = document.createElement('div');
            actions.className = 'stamp-actions';
            actions.innerHTML = `
                <button class="btn-copy" onclick="copyStamp(${stamp.id}, '${type}')">
                    <i class="fas fa-copy"></i>
                    Copiar
                </button>
                <button class="btn-clear" onclick="clearStampFields(${stamp.id}, '${type}')">
                    <i class="fas fa-eraser"></i>
                    Limpar
                </button>
                <button class="btn-delete" onclick="deleteStamp(${stamp.id}, '${type}')">
                    <i class="fas fa-trash-alt"></i>
                    Excluir
                </button>
            `;

            card.appendChild(header);
            card.appendChild(body);
            card.appendChild(actions);

            return card;
        }

        function updateFieldValue(stampId, fieldLabel, value, type) {
            const stamps = type === 'csc' ? stampsCSC : stampsPadrao;
            const stamp = stamps.find(s => s.id === stampId);
            if (stamp) {
                const field = stamp.fields.find(f => f.label === fieldLabel);
                if (field) {
                    field.value = value;
                    saveToLocalStorage(type);
                }
            }
        }

