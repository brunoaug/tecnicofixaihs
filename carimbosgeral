       function copyStamp(id, type) {
    const stamps = type === 'csc' ? stampsCSC : stampsPadrao;
    const stamp = stamps.find(s => s.id === id);
    if (!stamp) return;

    // Remove números do título (ex: "ATUALIZAÇÃO - 0002" vira "ATUALIZAÇÃO")
    let cleanTitle = stamp.title.replace(/\s*-\s*\d+$/, '').trim();
    
    let text = `${cleanTitle}\n`; 
    stamp.fields.forEach(field => {
        if (field.value) {
            text += `${field.label} ${field.value}\n`;
        }
    });

    navigator.clipboard.writeText(text).then(() => {
        showNotification('Carimbo copiado com sucesso!', 'success');
    }).catch(() => {
        showNotification('Erro ao copiar carimbo', 'error');
    });
}

        function copyAllStamps(type) {
            const stamps = type === 'csc' ? stampsCSC : stampsPadrao;
            let text = `CARIMBOS TLP - ${type.toUpperCase()}\n\n`;
            
            stamps.forEach(stamp => {
                text += `${stamp.title}\n`;
                stamp.fields.forEach(field => {
                    if (field.value) {
                        text += `${field.label} ${field.value}\n`;
                    }
                });
                text += '\n---\n\n';
            });

            navigator.clipboard.writeText(text).then(() => {
                showNotification('Todos os carimbos copiados!', 'success');
            }).catch(() => {
                showNotification('Erro ao copiar carimbos', 'error');
            });
        }

        function deleteStamp(id, type) {
            if (confirm('Tem certeza que deseja excluir este carimbo?')) {
                if (type === 'csc') {
                    stampsCSC = stampsCSC.filter(s => s.id !== id);
                } else {
                    stampsPadrao = stampsPadrao.filter(s => s.id !== id);
                }
                saveToLocalStorage(type);
                renderStamps(type);
                createFilterButtons(type);
                updateStats(type);
                showNotification('Carimbo excluído com sucesso!', 'success');
            }
        }

        function addNewStamp(type) {
            const title = prompt('Digite o título do novo carimbo:');
            if (!title) return;

            const category = prompt('Digite a categoria:');
            if (!category) return;

            const numFields = parseInt(prompt('Quantos campos?', '4'));
            if (isNaN(numFields) || numFields < 1) return;

            const stamps = type === 'csc' ? stampsCSC : stampsPadrao;
            const newId = Math.max(...stamps.map(s => s.id), 0) + 1;

            const colors = ['blue', 'green', 'purple', 'orange', 'yellow'];
            const randomColor = colors[Math.floor(Math.random() * colors.length)];

            const newStamp = {
                id: newId,
                title,
                category,
                color: randomColor,
                fields: []
            };

            for (let i = 0; i < numFields; i++) {
                const fieldLabel = prompt(`Nome do campo ${i + 1}:`, `Campo ${i + 1}:`);
                if (fieldLabel) {
                    newStamp.fields.push({
                        label: fieldLabel,
                        value: ""
                    });
                }
            }

            if (type === 'csc') {
                stampsCSC.push(newStamp);
            } else {
                stampsPadrao.push(newStamp);
            }

            saveToLocalStorage(type);
            renderStamps(type);
            createFilterButtons(type);
            updateStats(type);
            showNotification('Novo carimbo criado com sucesso!', 'success');
        }

        function searchStamps(type) {
            const searchInput = type === 'csc' ? 'searchInputCSC' : 'searchInputPadrao';
            const searchTerm = document.getElementById(searchInput).value.toLowerCase();
            const grid = type === 'csc' ? 'stampsGridCSC' : 'stampsGridPadrao';
            const cards = document.querySelectorAll(`#${grid} .stamp-card`);

            let visibleCount = 0;
            cards.forEach(card => {
                const text = card.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            updateStats(type, visibleCount);
        }

        function createFilterButtons(type) {
            const stamps = type === 'csc' ? stampsCSC : stampsPadrao;
            const categories = [...new Set(stamps.map(s => s.category))];
            const filterDiv = document.getElementById(type === 'csc' ? 'filterButtonsCSC' : 'filterButtonsPadrao');
            
            filterDiv.innerHTML = `<button class="filter-btn active" onclick="filterStamps('all', '${type}')">Todos</button>`;
            
            categories.forEach(cat => {
                const btn = document.createElement('button');
                btn.className = 'filter-btn';
                btn.textContent = cat;
                btn.onclick = () => filterStamps(cat, type);
                filterDiv.appendChild(btn);
            });
        }

        function filterStamps(category, type) {
            renderStamps(type, category);
            
            const filterDiv = type === 'csc' ? 'filterButtonsCSC' : 'filterButtonsPadrao';
            document.querySelectorAll(`#${filterDiv} .filter-btn`).forEach(btn => {
                btn.classList.remove('active');
                if ((category === 'all' && btn.textContent === 'Todos') || btn.textContent === category) {
                    btn.classList.add('active');
                }
            });
        }

        function updateStats(type, filteredCount = null) {
            const stamps = type === 'csc' ? stampsCSC : stampsPadrao;
            const totalId = type === 'csc' ? 'totalStampsCSC' : 'totalStampsPadrao';
            const filteredId = type === 'csc' ? 'filteredStampsCSC' : 'filteredStampsPadrao';
            
            document.getElementById(totalId).textContent = stamps.length;
            document.getElementById(filteredId).textContent = filteredCount !== null ? filteredCount : stamps.length;
        }

        function showNotification(message, type = 'success') {
            const notification = document.getElementById('notification');
            const icon = document.getElementById('notificationIcon');
            
            notification.className = `notification ${type}`;
            
            if (type === 'success') {
                icon.className = 'fas fa-check-circle';
            } else {
                icon.className = 'fas fa-exclamation-circle';
            }
            
            document.getElementById('notificationText').textContent = message;
            notification.classList.add('show');
            
            setTimeout(() => {
                notification.classList.remove('show');
            }, 3000);
        }

        function saveToLocalStorage(type) {
            if (type === 'csc') {
                localStorage.setItem('stampsCSC', JSON.stringify(stampsCSC));
            } else {
                localStorage.setItem('stampsPadrao', JSON.stringify(stampsPadrao));
            }
            showNotification('Dados salvos com sucesso!', 'success');
        }

        function loadFromLocalStorage() {
            const savedCSC = localStorage.getItem('stampsCSC');
            const savedPadrao = localStorage.getItem('stampsPadrao');
            
            if (savedCSC) {
                try {
                    stampsCSC = JSON.parse(savedCSC);
                } catch (e) {
                    console.error('Erro ao carregar carimbos CSC:', e);
                }
            }
            
            if (savedPadrao) {
                try {
                    stampsPadrao = JSON.parse(savedPadrao);
                } catch (e) {
                    console.error('Erro ao carregar carimbos padrão:', e);
                }
            }
        }

        window.onload = () => {
            loadTheme();
            loadFromLocalStorage();
        };
    </script>
</body>
</html>
